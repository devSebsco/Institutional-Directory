<section id="ubicacion" class="relative overflow-hidden" style="height:100vh;min-height:600px;">
  <video autoplay muted loop playsinline preload="none"
    class="absolute inset-0 w-full h-full object-cover z-0" style="pointer-events:none">
    <source src="/assets/videos/seccion-ubicacion-video.mp4" type="video/mp4">
  </video>
  <div class="absolute inset-0" style="z-index:1;background:linear-gradient(105deg,rgba(0,30,15,.85) 0%,rgba(0,82,34,.75) 35%,rgba(0,61,25,.45) 60%,rgba(0,40,15,.25) 100%)"></div>
  <div class="absolute inset-0" style="z-index:1;background-image:radial-gradient(circle at 75% 50%,rgba(34,197,94,.08) 0%,transparent 60%),radial-gradient(circle at 20% 80%,rgba(0,122,51,.12) 0%,transparent 40%)"></div>

  <div class="relative z-10 h-full flex flex-col lg:flex-row items-center px-6 lg:px-16 overflow-x-hidden box-border" style="padding-top:2rem;padding-bottom:5rem">

    <div class="w-full lg:w-2/5 flex flex-col justify-center flex-shrink-0 mb-8 lg:mb-0 lg:pr-6">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight mb-3 leading-tight">
        Nuestra <span style="color:#86efac">Ubicación</span>
      </h2>
      <div class="w-16 h-1 rounded-full mb-5" style="background:linear-gradient(90deg,#22c55e,#86efac)"></div>
      <p class="text-white/70 text-base leading-relaxed mb-8 max-w-sm">
        Ven y sé parte de nuestra comunidad universitaria en el corazón de Aguachica.
      </p>
      <div class="space-y-3">
        <div class="flex items-start gap-3 p-4 rounded-2xl border border-white/15 transition-all duration-300 hover:scale-105 hover:border-white/30" style="background:rgba(255,255,255,0.07);backdrop-filter:blur(16px)">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:linear-gradient(135deg,#007A33,#15803d)">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          </div>
          <div>
            <p class="text-white font-semibold text-sm">Dirección</p>
            <p class="text-white/60 text-xs mt-0.5 leading-relaxed">Cra. 40 #1 Norte-2, Cl. 1 Nte. #39-74, Aguachica, Cesar</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-2xl border border-white/15 transition-all duration-300 hover:scale-105 hover:border-white/30" style="background:rgba(255,255,255,0.07);backdrop-filter:blur(16px)">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0" style="background:linear-gradient(135deg,#007A33,#15803d)">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="text-white font-semibold text-sm">Horario de atención</p>
            <p class="text-white/60 text-xs mt-0.5 leading-relaxed">Lunes a Viernes, 8:00 a.m. – 12:00 m. y 3:00 p.m. – 7:00 p.m.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="w-full lg:w-3/5 flex flex-col gap-3 flex-shrink-0 lg:pl-6">
      <div class="rounded-3xl overflow-hidden border transition-all duration-300 hover:scale-[1.01]"
        style="border-color:rgba(255,255,255,0.18);background:rgba(255,255,255,0.06);backdrop-filter:blur(20px);box-shadow:0 24px 64px rgba(0,0,0,0.35),inset 0 1px 0 rgba(255,255,255,0.15)">
        <div class="flex items-center gap-2 px-5 py-3 border-b" style="border-color:rgba(255,255,255,0.1);background:rgba(0,0,0,0.15)">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full" style="background:rgb(246, 101, 82)"></div>
            <div class="w-3 h-3 rounded-full" style="background:rgb(250, 191, 47)"></div>
            <div class="w-3 h-3 rounded-full" style="background:rgb(41, 205, 63)"></div>
          </div>
          <div class="flex-1 mx-3 px-3 py-1 rounded-lg text-xs text-white/40 font-mono" style="background:rgba(255,255,255,0.06)">
            ¿Dónde queda la UPC Seccional Aguachica?
          </div>
          <img src="/assets/imagenes/loguito.webp" alt="UPC" class="w-5 h-5 object-contain animate-pulse rounded-sm" loading="lazy">
        </div>
        <div id="mapa-upc" style="height:360px"></div>
      </div>
    </div>
  </div>
</section>