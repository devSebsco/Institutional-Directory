<section id="directorio" class="relative isolate min-h-screen overflow-x-hidden"
  style="background-image:linear-gradient(160deg,rgba(0,20,10,.82),rgba(0,55,22,.72) 50%,rgba(0,40,15,.78)),url(/assets/imagenes/galeria-1.avif);background-size:cover;background-attachment:fixed;background-position:center">
  <div class="sticky top-0 h-screen w-full overflow-hidden z-0 pointer-events-none">
    <img src="/assets/imagenes/galeria-1.avif" alt="Background Entrada Universidad" class="absolute inset-0 w-full h-full object-cover">
    <div class="absolute inset-0" style="background:linear-gradient(160deg,rgba(0,20,10,.82) 0%,rgba(0,55,22,.72) 50%,rgba(0,40,15,.78) 100%)"></div>
  </div>

  <div class="relative z-10 -mt-[100vh] w-full">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-16">

      <div class="text-center mb-7">
        <h2 class="font-black tracking-tight leading-none mb-2 text-white text-[clamp(2.2rem,5.5vw,4rem)]">
          Directorio<br><span class="text-green-500">Institucional</span>
        </h2>
        <p class="text-white/55 text-[13px] mt-2">Personas que lideran la UPC Seccional Aguachica</p>
      </div>

      <div class="flex justify-center mb-5 duration-300 hover:scale-110">
        <div class="dir-search-wrap">
          <svg class="w-4 h-4 text-green-300/55" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
          <input type="text" id="searchInput" placeholder="Buscar nombre, cargo o área..."
            oninput="applyFilters()"
            class="bg-white/10 text-white placeholder:text-white/40 focus:bg-white/10 focus:outline-none">
        </div>
      </div>

      <div class="flex flex-wrap justify-center gap-2 mb-6">
        <button onclick="setFilter('all')"       id="btn-all"       class="dir-filter-btn dir-filter-active duration-300 hover:scale-105">Todos</button>
        <button onclick="setFilter('direccion')" id="btn-direccion" class="dir-filter-btn duration-300 hover:scale-105">Dirección</button>
        <button onclick="setFilter('academico')" id="btn-academico" class="dir-filter-btn duration-300 hover:scale-105">Académico</button>
        <button onclick="setFilter('admin')"     id="btn-admin"     class="dir-filter-btn duration-300 hover:scale-105">Administrativo</button>
        <button onclick="setFilter('bienestar')" id="btn-bienestar" class="dir-filter-btn duration-300 hover:scale-105">Bienestar</button>
      </div>

      <div class="relative overflow-visible">
        <button id="dir-arrow-prev" class="dir-arrow" onclick="dirPrev()">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <div id="dir-carousel-track"></div>
        <button id="dir-arrow-next" class="dir-arrow" onclick="dirNext()">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>

      <div id="dir-indicator"></div>
      <div id="dir-counter"></div>

      <div id="noResults" class="hidden text-center py-12">
        <p class="text-green-300/50 font-bold">Sin resultados</p>
        <p class="text-white/30 text-xs mt-1">Intenta con otra búsqueda</p>
      </div>

    </div>
  </div>
</section>