const sectionOrder = ['hero','directorio','video','podcast','identidad','ubicacion'];
let currentSectionIndex = 0;

function scrollToSection(id) {
    const idx = sectionOrder.indexOf(id);
    if (idx === -1) return;
    currentSectionIndex = idx;
    document.getElementById('sections-container').style.transform = `translateX(-${idx * 100}vw)`;
    const target = document.getElementById(id);
    if (target) target.scrollTop = 0;
    document.querySelectorAll('.dock-item').forEach((item, i) => item.classList.toggle('active', i === idx));
    const hint = document.getElementById('swipe-hint');
    if (hint) hint.classList.toggle('left', idx === sectionOrder.length - 1);
}

let currentFilter = 'all';
let searchDebounceTimer = null;

function setFilter(cat) {
    currentFilter = cat;
    document.querySelectorAll('.dir-filter-btn').forEach(b => b.classList.remove('dir-filter-active'));
    document.getElementById('btn-' + cat)?.classList.add('dir-filter-active');
    applyFilters();
}

function applyFilters() {
    clearTimeout(searchDebounceTimer);
    searchDebounceTimer = setTimeout(() => {
        const query = document.getElementById('searchInput').value.toLowerCase().trim();
        renderCards(directorio.filter(p =>
            (currentFilter === 'all' || p.categoria === currentFilter) &&
            (!query || [p.nombre, p.cargo, p.descripcion, p.categoria].some(v => v.toLowerCase().includes(query)))
        ));
    }, 200);
}

const catColors  = { direccion:'#22c55e', academico:'#4ade80', admin:'#86efac', bienestar:'#bbf7d0' };
let dirItems = [], dirIndex = 0, dirAnimating = false;
let dirTouchStartX = 0, dirTouchStartY = 0;

const dirGetInitials = n => n.split(' ').slice(0,2).map(w => w[0]).join('').toUpperCase();

function dirBuildSlide({ nombre, cargo, categoria, descripcion, email }) {
    return `<div class="dir-slide-inner">
        <div style="display:flex;align-items:flex-start;gap:12px;">
            <div class="dir-card-avatar" style="color:${catColors[categoria] || '#22c55e'}">${dirGetInitials(nombre)}</div>
            <div style="min-width:0;flex:1;">
                <p style="font-weight:800;font-size:13px;color:#fff;line-height:1.35;margin-bottom:4px;">${nombre}</p>
                <span class="dir-card-badge">${cargo}</span>
            </div>
        </div>
        <div class="dir-card-desc">${descripcion}</div>
        <a href="mailto:${email}" class="dir-card-email">
            <svg style="width:13px;height:13px;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            <span>${email}</span>
        </a>
    </div>`;
}

function dirRender() {
    const track     = document.getElementById('dir-carousel-track');
    const noResults = document.getElementById('noResults');
    const indicator = document.getElementById('dir-indicator');
    const counter   = document.getElementById('dir-counter');
    if (!track) return;

    if (!dirItems.length) {
        track.innerHTML = indicator.innerHTML = counter.textContent = '';
        noResults.classList.remove('hidden');
        return;
    }
    noResults.classList.add('hidden');
    dirIndex = ((dirIndex % dirItems.length) + dirItems.length) % dirItems.length;

    const total   = dirItems.length;
    const offsets = total === 1 ? [0] : total === 2 ? [-1,0,1] : [-2,-1,0,1,2];
    const posMap  = {'-2':'prev2','-1':'prev1','0':'active','1':'next1','2':'next2'};

    Array.from(track.children).forEach(c => { c.style.opacity = '0'; c.style.transform += ' scale(0.95)'; });

    setTimeout(() => {
        track.innerHTML = '';
        offsets.forEach(o => {
            const slide = document.createElement('div');
            slide.className = 'dir-slide ' + (posMap[String(o)] || 'hidden-slide');
            slide.style.opacity = '0';
            slide.innerHTML = dirBuildSlide(dirItems[((dirIndex + o) % total + total) % total]);
            if (o !== 0) slide.onclick = () => { if (!dirAnimating) dirGo(o); };
            track.appendChild(slide);
        });
        track.offsetHeight;
        Array.from(track.children).forEach((c, i) => setTimeout(() => { c.style.opacity = ''; }, i * 30));
        dirAnimating = false;
        track.style.pointerEvents = '';
    }, 120);

    if (indicator) {
        const maxDots = Math.min(total, 10);
        indicator.innerHTML = '';
        for (let i = 0; i < maxDots; i++) {
            const dot = document.createElement('div');
            dot.className = 'dir-dot' + (i === dirIndex % maxDots ? ' active' : '');
            dot.onclick = () => { if (!dirAnimating) { dirIndex = i; dirAnimate(); } };
            indicator.appendChild(dot);
        }
    }
    if (counter) counter.textContent = `${dirIndex + 1} / ${total}`;
}

function dirAnimate() {
    if (dirAnimating) return;
    dirAnimating = true;
    const track = document.getElementById('dir-carousel-track');
    if (track) track.style.pointerEvents = 'none';
    dirRender();
}

function dirGo(offset) {
    dirIndex = (dirIndex + offset + dirItems.length) % dirItems.length;
    dirAnimate();
}

function dirNext() { if (!dirAnimating && dirItems.length) dirGo(1); }
function dirPrev() { if (!dirAnimating && dirItems.length) dirGo(-1); }

function renderCards(items) {
    dirItems = Array.isArray(items) ? [...items] : [];
    dirIndex = 0;
    dirAnimating = false;
    dirRender();
}

const identidadItems = ['escudo','bandera','himno','logo','colores'];

function toggleIdentidad(id) {
    const isOpen = !document.getElementById('panel-' + id).classList.contains('hidden');
    identidadItems.forEach(item => {
        document.getElementById('panel-' + item).classList.add('hidden');
        document.getElementById('arrow-' + item).style.transform = 'rotate(0deg)';
    });
    if (!isOpen) {
        document.getElementById('panel-' + id).classList.remove('hidden');
        document.getElementById('arrow-' + id).style.transform = 'rotate(180deg)';
    }
}

function revealOnScroll() {
    document.querySelectorAll('.reveal:not(.visible)').forEach(el => {
        if (el.getBoundingClientRect().top < window.innerHeight * 0.88)
            el.classList.add('visible');
    });
}

function typeWriter(id, text, speed, cb) {
    const el = document.getElementById(id);
    let i = 0;
    const type = () => i < text.length
        ? (el.textContent += text[i++], setTimeout(type, speed))
        : cb?.();
    type();
}

let galeriaIndex = 0;
const galeriaTotal = 6;
let galeriaTimer = null;

function galeriaIr(idx) {
    galeriaIndex = idx;
    document.getElementById('galeria-slides').style.transform = `translateX(-${idx * 20}%)`;
    document.querySelectorAll('.galeria-dot').forEach((dot, i) => {
        dot.style.background = i === idx ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.4)';
        dot.style.width      = i === idx ? '24px' : '8px';
        dot.style.borderRadius = '9999px';
    });
}

function galeriaSiguiente() { galeriaIr((galeriaIndex + 1) % galeriaTotal); reiniciarTimerGaleria(); }
function galeriaAnterior()  { galeriaIr((galeriaIndex - 1 + galeriaTotal) % galeriaTotal); reiniciarTimerGaleria(); }
function reiniciarTimerGaleria() { clearInterval(galeriaTimer); galeriaTimer = setInterval(galeriaSiguiente, 5000); }

const podcastLines = [
    { text: 'LA UPC',   color: '#ffffff' },
    { text: 'Y LA',     color: '#22c55e' },
    { text: 'CONSULTA', color: '#ffffff' },
    { text: 'POPULAR',  color: '#22c55e' },
];

function runPodcastTypewriter() {
    const el = document.getElementById('podcast-typewriter');
    if (!el) return;

    const cursor = document.createElement('span');
    cursor.className = 'tw-cursor';
    cursor.style.cssText = 'display:inline-block;width:3px;height:0.85em;background:#22c55e;vertical-align:middle;position:relative;top:-4px;animation:parpadeo 0.7s step-end infinite;margin-left:3px;';

    const spans = [];
    let li = 0, ci = 0;
    let mode = 'typing';

    function reset() {
        el.innerHTML = '';
        el.appendChild(cursor);
        spans.length = 0;
        li = 0; ci = 0;
        mode = 'typing';
    }

    function ensureSpan(idx) {
        if (!spans[idx]) {
            const s = document.createElement('span');
            s.style.cssText = `color:${podcastLines[idx].color};display:block;`;
            if (cursor.parentNode !== el) el.appendChild(cursor);
            el.insertBefore(s, cursor);
            spans[idx] = s;
        }
        return spans[idx];
    }

    function moveCursorTo(span) {
        if (cursor.parentNode !== span) {
            span.appendChild(cursor);
        }
    }

    function step() {
        if (mode === 'typing') {
            if (li >= podcastLines.length) {
                mode = 'erasing';
                li = podcastLines.length - 1;
                ci = podcastLines[li].text.length;
                setTimeout(step, 2500);
                return;
            }
            const line = podcastLines[li];
            const span = ensureSpan(li);
            ci++;
            span.textContent = line.text.substring(0, ci);
            moveCursorTo(span);
            const delay = ci >= line.text.length ? 180 : 70;
            if (ci >= line.text.length) { li++; ci = 0; }
            setTimeout(step, delay);
        } else {
            if (li < 0) { reset(); setTimeout(step, 500); return; }
            const line = podcastLines[li];
            const span = spans[li];
            if (ci <= 0) {
                if (span && span.parentNode) span.remove();
                delete spans[li];
                li--;
                if (li >= 0) ci = podcastLines[li].text.length;
                setTimeout(step, 80);
                return;
            }
            ci--;
            span.textContent = line.text.substring(0, ci);
            moveCursorTo(span);
            setTimeout(step, 40);
        }
    }

    reset();
    step();
}

const collageSrcs = [
    'assets/imagenes/consulta-1.webp',
    'assets/imagenes/consulta-0.webp',
    'assets/imagenes/consulta-3.webp',
    'assets/imagenes/consulta-5.webp',
];
let collageOffset = 0;

function rotarCollage() {
    collageOffset = (collageOffset + 1) % collageSrcs.length;
    for (let i = 0; i < 4; i++) {
        const img = document.getElementById('cell-' + i)?.querySelector('img');
        if (!img) continue;
        img.style.opacity = '0';
        setTimeout(() => { img.src = collageSrcs[(i + collageOffset) % collageSrcs.length]; img.style.opacity = '1'; }, 450);
    }
    document.querySelectorAll('.collage-dot-item').forEach((d, i) => d.classList.toggle('active', i === collageOffset % 4));
}

let touchStartX = 0, touchStartY = 0, touchStartTime = 0;

window.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    touchStartTime = Date.now();
}, { passive:true });

window.addEventListener('touchend', e => {
    if (window.innerWidth >= 768) return;
    const deltaX = e.changedTouches[0].clientX - touchStartX;
    const deltaY = e.changedTouches[0].clientY - touchStartY;
    if (Date.now() - touchStartTime > 400 || Math.abs(deltaX) < 50 || Math.abs(deltaY) > Math.abs(deltaX) * 0.6) return;
    scrollToSection(sectionOrder[currentSectionIndex + (deltaX < 0 ? 1 : -1)] || sectionOrder[currentSectionIndex]);
}, { passive:true });

window.addEventListener('wheel',     e => { if (!e.target.closest('#sections-container > section')) e.preventDefault(); }, { passive:false });
window.addEventListener('touchmove', e => { if (!e.target.closest('#sections-container > section')) e.preventDefault(); }, { passive:false });

window.addEventListener('keydown', e => {
    if (['PageUp','PageDown','Home','End'].includes(e.key)) { e.preventDefault(); return; }
    if (e.key === 'ArrowRight' && currentSectionIndex < sectionOrder.length - 1) { e.preventDefault(); scrollToSection(sectionOrder[currentSectionIndex + 1]); }
    if (e.key === 'ArrowLeft'  && currentSectionIndex > 0)                        { e.preventDefault(); scrollToSection(sectionOrder[currentSectionIndex - 1]); }
});

document.addEventListener('DOMContentLoaded', () => {
    typeWriter('typewriter-1', 'Directorio', 100, () => setTimeout(() => typeWriter('typewriter-2', 'Institucional', 100), 200));

    renderCards(directorio);
    document.querySelectorAll('.dock-item')[0]?.classList.add('active');

    const track = document.getElementById('dir-carousel-track');
    if (track) {
        track.addEventListener('touchstart', e => {
            dirTouchStartX = e.touches[0].clientX;
            dirTouchStartY = e.touches[0].clientY;
        }, { passive:true });
        track.addEventListener('touchmove', e => {
            const dx = Math.abs(e.touches[0].clientX - dirTouchStartX);
            const dy = Math.abs(e.touches[0].clientY - dirTouchStartY);
            if (dx > 15 && dx > dy * 1.5) e.stopPropagation();
        }, { passive:true });
    }

    const map = L.map('mapa-upc', { zoomControl:true, scrollWheelZoom:false }).setView([8.31480, -73.59644], 16);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', { attribution:'© OpenStreetMap © CARTO', maxZoom:19 }).addTo(map);
    L.marker([8.315, -73.59644], {
        icon: L.divIcon({
            className: '',
            html: `<div class="animate-bounce" style="width:44px;height:44px;">
                <div style="background:#15803d;border:3px solid #fff;border-radius:50% 50% 50% 0;width:100%;height:100%;transform:rotate(-45deg);box-shadow:0 4px 12px rgba(0,122,51,.4);display:flex;align-items:center;justify-content:center;">
                    <img src="assets/imagenes/loguito.webp" style="width:28px;height:28px;object-fit:contain;transform:rotate(45deg);border-radius:50%;"/>
                </div>
            </div>`,
            iconSize:[44,44], iconAnchor:[22,44], popupAnchor:[0,-48],
        })
    }).addTo(map).bindPopup('<strong style="color:#007A33">UPC Seccional Aguachica</strong><br>Cra. 40 #1 Norte, Aguachica, Cesar').openPopup();

    revealOnScroll();
    document.querySelectorAll('#sections-container > section').forEach(s => s.addEventListener('scroll', revealOnScroll, { passive:true }));

    document.querySelectorAll('.dock-item').forEach(item => {
        item.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); item.click(); } });
    });

    document.querySelectorAll('audio').forEach(a => a.addEventListener('contextmenu', e => e.preventDefault()));

    galeriaIr(0);
    galeriaTimer = setInterval(galeriaSiguiente, 5000);

    runPodcastTypewriter();
    setInterval(rotarCollage, 5000);
});
</script>
